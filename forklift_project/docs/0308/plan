A1. VisualActorCritic 网络定义

import torch
import torch.nn as nn

class VisualActor(nn.Module):
    def __init__(self, img_channels=3, easy8_dim=8, action_dim=3,
                 img_feat_dim=64, prop_feat_dim=32):
        super().__init__()
        
        # CNN backbone
        self.cnn = nn.Sequential(
            nn.Conv2d(img_channels, 16, 5, stride=2), nn.ReLU(),
            nn.Conv2d(16, 32, 3, stride=2), nn.ReLU(),
            nn.Conv2d(32, 32, 3, stride=2), nn.ReLU(),
            nn.Flatten(),
        )
        # 计算 CNN 输出维度 (取决于输入分辨率)
        # 对于 64x64 输入: 30->14->6, flatten=32*6*6=1152
        self.cnn_fc = nn.Sequential(
            nn.Linear(1152, img_feat_dim), nn.ReLU()
        )
        
        # Proprioception MLP
        self.prop_mlp = nn.Sequential(
            nn.Linear(easy8_dim, prop_feat_dim), nn.ReLU(),
            nn.Linear(prop_feat_dim, prop_feat_dim), nn.ReLU(),
        )
        
        # Policy head
        fused_dim = img_feat_dim + prop_feat_dim
        self.policy_head = nn.Sequential(
            nn.Linear(fused_dim, 64), nn.ReLU(),
            nn.Linear(64, 64), nn.ReLU(),
            nn.Linear(64, action_dim),  # action mean
        )
        
        # Learnable log_std
        self.log_std = nn.Parameter(torch.zeros(action_dim))
    
    def forward(self, obs_dict):
        """
        obs_dict: {
            "image": (B, 3, 64, 64),
            "proprioception": (B, 8),
        }
        """
        img = obs_dict["image"]
        prop = obs_dict["proprioception"]
        
        img_feat = self.cnn_fc(self.cnn(img))
        prop_feat = self.prop_mlp(prop)
        
        fused = torch.cat([img_feat, prop_feat], dim=-1)
        action_mean = self.policy_head(fused)
        action_mean = torch.tanh(action_mean)  # bound to [-1, 1]
        
        return action_mean, self.log_std.expand_as(action_mean)


class AsymmetricCritic(nn.Module):
    def __init__(self, privileged_dim=22):
        super().__init__()
        
        self.mlp = nn.Sequential(
            nn.Linear(privileged_dim, 128), nn.ReLU(),
            nn.Linear(128, 128), nn.ReLU(),
            nn.Linear(128, 64), nn.ReLU(),
            nn.Linear(64, 1),
        )
    
    def forward(self, privileged_obs):
        """
        privileged_obs: (B, 22)
        """
        return self.mlp(privileged_obs)


