A3. Action Smoothing 实现

class ActionSmoother:
    def __init__(self, alpha=0.6, steer_rate_limit=0.15, lift_rate_limit=0.1):
        self.alpha = alpha
        self.steer_rate_limit = steer_rate_limit
        self.lift_rate_limit = lift_rate_limit
        self.prev_action = None
    
    def smooth(self, raw_action):
        """
        raw_action: (B, 3) — [drive, steer, lift]
        """
        if self.prev_action is None:
            self.prev_action = raw_action.clone()
            return raw_action
        
        # EMA smoothing
        smoothed = self.alpha * raw_action + (1 - self.alpha) * self.prev_action
        
        # Rate limiting on steer
        delta_steer = smoothed[:, 1] - self.prev_action[:, 1]
        delta_steer = torch.clamp(delta_steer, 
                                   -self.steer_rate_limit, 
                                   self.steer_rate_limit)
        smoothed[:, 1] = self.prev_action[:, 1] + delta_steer
        
        # Rate limiting on lift
        delta_lift = smoothed[:, 2] - self.prev_action[:, 2]
        delta_lift = torch.clamp(delta_lift, 
                                  -self.lift_rate_limit, 
                                  self.lift_rate_limit)
        smoothed[:, 2] = self.prev_action[:, 2] + delta_lift
        
        self.prev_action = smoothed.clone()
        return smoothed
    
    def reset(self, env_ids):
        """Call on episode reset."""
        if self.prev_action is not None:
            self.prev_action[env_ids] = 0.0


